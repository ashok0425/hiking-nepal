<IfModule mod_rewrite.c>
    RewriteEngine on

    # Block access to sensitive files
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^\.env\..*$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^package(-lock)?\.json$ - [F,L]
    RewriteRule ^artisan$ - [F,L]
    RewriteRule ^storage/ - [F,L]
    RewriteRule ^\.git - [F,L]

    # Force HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Force www (canonical host)
    RewriteCond %{HTTP_HOST} ^hikingnepal\.com$ [NC]
    RewriteRule ^(.*)$ https://www.hikingnepal.com/$1 [L,R=301]

    # 301 redirect /public/* to /*  (strip leaked /public/ prefix)
    RewriteCond %{THE_REQUEST} \s/+public/([^\s?]*) [NC]
    RewriteRule ^ /%1 [L,R=301,NE]

    # Route all other requests into Laravel's public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
