<IfModule mod_rewrite.c>
    RewriteEngine on

    # Block access to sensitive files
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^\.env\..*$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^artisan$ - [F,L]
    RewriteRule ^\.git - [F,L]

    # Force www (canonical host) — preserves the original scheme via %{REQUEST_SCHEME}
    RewriteCond %{HTTP_HOST} ^hikingnepal\.com$ [NC]
    RewriteRule ^(.*)$ https://www.hikingnepal.com/$1 [L,R=301,NE]

    # 301 redirect /public and /public/* to / and /*  (strip leaked /public prefix)
    RewriteCond %{REQUEST_URI} ^/public(/.*)?$ [NC]
    RewriteRule ^public/?(.*)$ /$1 [L,R=301,NE]

    # Route all other requests into Laravel's public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
